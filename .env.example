# Your blog's base URL — a *.velocms.org subdomain or a bound custom domain.
# No trailing slash needed; the client normalizes it.
VELOCMS_SITE_URL=https://myblog.velocms.org

# API key from your VeloCMS dashboard: /admin/settings -> API Keys.
# Requires the Pro plan or higher. Format: velo_your_64_char_hex_key_here
VELOCMS_API_KEY=
